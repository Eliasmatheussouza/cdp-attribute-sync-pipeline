# 2 - Endpoint, test environment, production environment and payload limit

INSIDER_API_URL     = "https://unification.useinsider.com/api/user/v1/upsert"

#PARTNER_NAME       = "your_partner_name_test" # test
#REQUEST_TOKEN      = "your_request_token_test" # test

PARTNER_NAME        = "your_partner_name" # prod
REQUEST_TOKEN       = "your_request_token" # prod

API_PAYLOAD_LIMIT   = 1000

# 3 - BigQuery authentication

# BigQuery Customer query

client = bigquery.Client()

QUERY = """
WITH cleaned AS (
  SELECT
    email,
    contrato_cdc
  FROM `your-project.your_dataset.your_table`
  WHERE
    DATE(updatedAtInsider) = CURRENT_DATE()
    AND REGEXP_CONTAINS(TRIM(email), '@[a-zA-Z0-9-]+\\\\.[a-zA-Z0-9-.]+')
    AND LENGTH(TRIM(email)) - LENGTH(REPLACE(TRIM(email), '@', '')) = 1
    AND TRIM(email) NOT LIKE '% %'
)

SELECT *
FROM cleaned
"""

query_job = client.query(QUERY)
df = query_job.to_dataframe()

print("Records loaded:", len(df))

df
df['contrato_cdc'].dtype

# 5 - Sending the request

from tqdm import tqdm

headers = {
    "X-PARTNER-NAME": PARTNER_NAME,
    "X-REQUEST-TOKEN": REQUEST_TOKEN,
    "Content-Type": "application/json"
}

users_data = []
count_rows = 0

if df.empty:
    print("No records found. Exiting.")

else:
    for _, row in tqdm(df.iterrows(), total=len(df), desc="Sending batches"):

        user_payload = {
            "identifiers": {"email": row["email"]},
            "attributes": {
                "custom": {
                    "cdc_contrato": row["contrato_cdc"]
                }
            }
        }

        users_data.append(user_payload)
        count_rows += 1

        if count_rows == API_PAYLOAD_LIMIT:
            try:
                response = requests.post(
                    INSIDER_API_URL,
                    headers=headers,
                    json={"users": users_data}
                )
                try:
                    echo_response = response.json()
                except:
                    echo_response = response.text

            except Exception as e:
                print("\nBATCH ERROR:")
                print(e)
                print(json.dumps({"users": users_data}, indent=2))

            users_data = []
            count_rows = 0

    if users_data:
        response = requests.post(
            INSIDER_API_URL,
            headers=headers,
            json={"users": users_data}
        )

    if 'response' in dir():
        try:
            echo_response = response.json()
        except:
            echo_response = response.text

        print("\nFinal API response:", echo_response)
        print(f"Total sent to Insider: {len(df)}")

# --- THIS IS THE LAST CELL OF THE NOTEBOOK ---
# If the notebook reached here without errors, we send the final OK.

