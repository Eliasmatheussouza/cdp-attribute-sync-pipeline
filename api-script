# --- CONFIGURATION ---
TEAMS_WEBHOOK = "https://your-tenant.webhook.office.com/webhookb2/YOUR_WEBHOOK_ID/IncomingWebhook/YOUR_WEBHOOK_TOKEN"

class JobMonitor:
    def __init__(self, job_name, webhook_url):
        self.job_name = job_name
        self.webhook_url = webhook_url
        self.start_time = time.time()

    def send_alert(self, status, message, details=""):
        # Define color: Green for success, Red for error
        color = "00FF00" if status == "Sucesso" else "FF0000"

        # Fixed duration calculation
        duration_seconds = int(time.time() - self.start_time)
        duration = str(timedelta(seconds=duration_seconds))

        # String handling for Teams JSON
        # We add code blocks (```) to make the error readable
        safe_details = str(details).replace('"', "'").replace("\\", "/")
        if status != "Sucesso":
            safe_details = f"```\n{safe_details[:500]}\n```"

        payload = {
            "@type": "MessageCard",
            "@context": "[http://schema.org/extensions](http://schema.org/extensions)",
            "themeColor": color,
            "summary": "Processing Monitor",
            "sections": [{
                "activityTitle": f"🚀 Job: {self.job_name}",
                "activitySubtitle": f"**Status:** {status}",
                "facts": [
                    {"name": "⏱ Duration:", "value": duration},
                    {"name": "📝 Message:", "value": message},
                    {"name": "💻 Technical Info:", "value": safe_details}
                ],
                "markdown": True
            }]
        }

        try:
            r = requests.post(self.webhook_url, json=payload, timeout=15)
            print(f"Notification sent to Teams. Status Code: {r.status_code}")
        except Exception as e:
            print(f"Failed to send webhook: {e}")

# Instantiating the monitor
monitor = JobMonitor("CDC ATTRIBUTE - APPROVED WITHOUT CONTRACT", TEAMS_WEBHOOK)

